      ["data"] = new Dictionary<string, object> { ["name"] = "Walter" }
    },
    new Dictionary<string, object>
    {
      ["action"] = "increment",
      ["databaseId"] = "<DB_B>",
      ["collectionId"] = "<COLLECTION_2>",
      ["documentId"] = "u2",
      ["data"] = new Dictionary<string, object> { ["value"] = 1, ["min"] = 0, ["attribute"] = "credits" }
    }
  }
);
```
