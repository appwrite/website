            json!({
                "$id": ID::unique(),
                "$createdAt": "2024-02-01T00:00:00.000Z",
                "$updatedAt": "2024-02-01T00:00:00.000Z",
                "embeddings": [0.2, 0.2, 0.2, 0.2],
                "metadata": { "batch": 2 }
            }),
        ],
    ).await?;

    println!("Bulk create: {:?}", result);
    Ok(())
}
