            ["metadata"] = new Dictionary<string, object> { ["batch"] = 1 }
        },
        new Dictionary<string, object>
        {
            ["$id"] = ID.Unique(),
            ["$createdAt"] = second,
            ["$updatedAt"] = second,
            ["embeddings"] = new List<double> { 0.2, 0.2, 0.2, 0.2 },
            ["metadata"] = new Dictionary<string, object> { ["batch"] = 2 }
        }
    }
);
```
```server-dart
