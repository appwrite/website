        json!({
            "$createdAt": "<ORIGINAL_CREATED_AT_ISO>",
            "$updatedAt": "<LAST_MODIFIED_ISO>",
            "embeddings": [0.12, 0.84, 0.33, 0.57],
            "metadata": { "title": "Imported post" }
        }),
        None, // permissions (optional)
    ).await?;

    println!("Created: {:?}", result);
    Ok(())
}
