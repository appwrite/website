```server-go
package main

import (
    "fmt"

    "github.com/appwrite/sdk-for-go/apps"
    "github.com/appwrite/sdk-for-go/client"
    "github.com/appwrite/sdk-for-go/id"
)

func main() {
    c := client.New(
        client.WithEndpoint("https://cloud.appwrite.io/v1"),
        client.WithProject("console"),
        client.WithSession(""), // Your Appwrite account session
    )

    service := apps.New(c)

    app, err := service.Create(
        id.Unique(),
        "Horizon",
        []string{"https://horizon.example.com/oauth/callback"},
        apps.WithCreateDescription("Deployment dashboard for your Appwrite projects."),
        apps.WithCreateTagline("Ship from one place"),
        apps.WithCreateLogoUri("https://horizon.example.com/logo.png"),
        apps.WithCreateClientUri("https://horizon.example.com"),
        apps.WithCreatePrivacyPolicyUrl("https://horizon.example.com/privacy"),
        apps.WithCreateTermsUrl("https://horizon.example.com/terms"),
        apps.WithCreateType("confidential"),
    )
    if err != nil {
        panic(err)
    }

    fmt.Println(app)
}
```

```server-rust
use appwrite::Client;
use appwrite::id::ID;
use appwrite::services::Apps;

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let client = Client::new();
    client.set_endpoint("https://cloud.appwrite.io/v1");
    client.set_project("console");
    client.set_session(""); // Your Appwrite account session

    let apps = Apps::new(&client);

    let app = apps.create(
        &ID::unique(),
        "Horizon",
        vec!["https://horizon.example.com/oauth/callback"],
        Some("Deployment dashboard for your Appwrite projects."),
        Some("https://horizon.example.com"),
        Some("https://horizon.example.com/logo.png"),
        Some("https://horizon.example.com/privacy"),
        Some("https://horizon.example.com/terms"),
        None,
        Some("Ship from one place"),
        None,
        None,
        None,
        None,
        None,
        None,
        Some("confidential"),
        None,
        None,
    ).await?;

    println!("{}", app.id);

    Ok(())
}
```
{% /multicode %}

The consent screen shows the name, logo, and tagline on the authorization card, and links the privacy policy and terms of service in its footer. `description`, `tags`, `images`, `supportUrl`, `dataDeletionUrl`, and `contacts` complete the listing where apps are browsed.

Redirect URIs match exactly, with one exception: public clients may register loopback URIs (`http://127.0.0.1`, `http://localhost`), which match on any port. Redirect URIs must use HTTPS, a loopback address, or a private-use scheme such as `com.example.app:/callback` for native apps.

# Secrets {% #secrets %}

Confidential clients authenticate with a secret. Create one after registering:

{% multicode %}
```server-nodejs
import { Client, Apps } from 'node-appwrite';

const client = new Client()
    .setEndpoint('https://cloud.appwrite.io/v1')
    .setProject('console')
    .setSession(''); // Your Appwrite account session

const apps = new Apps(client);

const secret = await apps.createSecret({
    appId: '<APP_ID>'
});

console.log(secret.secret); // Shown only once
```

```server-deno
import { Client, Apps } from 'npm:node-appwrite';

const client = new Client()
    .setEndpoint('https://cloud.appwrite.io/v1')
    .setProject('console')
    .setSession(''); // Your Appwrite account session

const apps = new Apps(client);

const secret = await apps.createSecret({
    appId: '<APP_ID>'
});

console.log(secret.secret); // Shown only once
```

```server-python
from appwrite.client import Client
from appwrite.services.apps import Apps

client = Client()
client.set_endpoint('https://cloud.appwrite.io/v1')
client.set_project('console')
client.set_session('')  # Your Appwrite account session

apps = Apps(client)

secret = apps.create_secret(
    app_id = '<APP_ID>'
)

print(secret.secret)  # Shown only once
```

