```server-java
import io.appwrite.Client;
import io.appwrite.ID;
import io.appwrite.coroutines.CoroutineCallback;
import io.appwrite.services.Apps;

Client client = new Client()
    .setEndpoint("https://cloud.appwrite.io/v1")
    .setProject("console")
    .setSession(""); // Your Appwrite account session

Apps apps = new Apps(client);

apps.create(
    ID.unique(), // appId
    "Horizon", // name
    List.of("https://horizon.example.com/oauth/callback"), // redirectUris
    "Deployment dashboard for your Appwrite projects.", // description
    "https://horizon.example.com", // clientUri
    "https://horizon.example.com/logo.png", // logoUri
    "https://horizon.example.com/privacy", // privacyPolicyUrl
    "https://horizon.example.com/terms", // termsUrl
    null, // contacts
    "Ship from one place", // tagline
    null, // tags
    null, // images
    null, // supportUrl
    null, // dataDeletionUrl
    null, // postLogoutRedirectUris
    null, // enabled
    "confidential", // type
    null, // deviceFlow
    null, // teamId
    new CoroutineCallback<>((app, error) -> {
        if (error != null) {
            error.printStackTrace();
            return;
        }

        System.out.println(app);
    })
);
```

