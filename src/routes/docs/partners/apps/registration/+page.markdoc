```server-python
from appwrite.client import Client
from appwrite.services.apps import Apps
from appwrite.id import ID

client = Client()
client.set_endpoint('https://cloud.appwrite.io/v1')
client.set_project('console')
client.set_session('')  # Your Appwrite account session

apps = Apps(client)

app = apps.create(
    app_id = ID.unique(),
    name = 'Horizon',
    redirect_uris = ['https://horizon.example.com/oauth/callback'],
    description = 'Deployment dashboard for your Appwrite projects.',
    tagline = 'Ship from one place',
    logo_uri = 'https://horizon.example.com/logo.png',
    client_uri = 'https://horizon.example.com',
    privacy_policy_url = 'https://horizon.example.com/privacy',
    terms_url = 'https://horizon.example.com/terms',
    type = 'confidential'
)
```

