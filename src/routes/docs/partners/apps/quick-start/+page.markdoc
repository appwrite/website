```server-dotnet
using Appwrite;
using Appwrite.Models;
using Appwrite.Services;

Client client = new Client()
    .SetEndPoint("https://cloud.appwrite.io/v1")
    .SetProject("console")
    .SetSession(""); // Your Appwrite account session

Apps apps = new Apps(client);

