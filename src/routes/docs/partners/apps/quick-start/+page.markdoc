    ->setSession(''); // Your Appwrite account session

$apps = new Apps($client);

$app = $apps->create(
    appId: ID::unique(),
    name: 'Horizon',
    redirectUris: ['http://localhost:7700/oauth/callback'],
    type: 'confidential'
);

$secret = $apps->createSecret(appId: $app['$id']);
```

