});

const secret = await apps.createSecret({ appId: app.$id });
```

```server-python
from appwrite.client import Client
from appwrite.services.apps import Apps
from appwrite.id import ID

client = Client()
client.set_endpoint('https://cloud.appwrite.io/v1')
client.set_project('console')
client.set_session('')  # Your Appwrite account session

apps = Apps(client)

app = apps.create(
    app_id = ID.unique(),
    name = 'Horizon',
    redirect_uris = ['http://localhost:7700/oauth/callback'],
    type = 'confidential'
)

secret = apps.create_secret(app_id = app.id)
```

```server-php
<?php

