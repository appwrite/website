```server-nodejs
const result = await tablesDB.updateRow({
    databaseId: '<DATABASE_ID>',
    tableId: '<TABLE_ID>',
    rowId: '<ROW_ID>',
    data: {
        total_views: sdk.Operator.increment(1)
    }
});
```

